{
  "name": "APPNAME",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "displayName": "APPNAME",
  "description": "A Cribl Search App",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "package": "npm run build && cribl-app-package",
    "deploy": "cribl-app-deploy",
    "inspect:pack": "cribl-app-inspect",
    "release:evidence": "cribl-app-release-evidence",
    "security:static": "cribl-app-security",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "npx playwright test"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@cribl/app-tooling": "file:../cribl-search-app-framework/packages/app-tooling",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.45.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright-core": "^1.45.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
